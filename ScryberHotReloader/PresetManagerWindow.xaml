<Window x:Class="ScryberHotReloader.PresetManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Preset Manager" Width="740" Height="520"
        WindowStyle="None" AllowsTransparency="True"
        Background="#1e1e1e" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#9CDCFE"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="Input" TargetType="TextBox">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="CaretBrush" Value="#AEAFAD"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#007ACC"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#505050"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#2A2A2A"/>
                    <Setter Property="Foreground" Value="#555"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PrimaryBtn" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="#007ACC"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#005F9E"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#2A2A2A"/>
                    <Setter Property="Foreground" Value="#555"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="#6B2020"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#8B2828"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#2A2A2A"/>
                    <Setter Property="Foreground" Value="#555"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="CloseBtn" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E81123"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#444" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="#252526" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="Preset Manager" Foreground="#D4D4D4" FontWeight="SemiBold"
                               FontSize="13" VerticalAlignment="Center" Margin="14,0"/>
                    <Button Content="✕" HorizontalAlignment="Right" Width="40"
                            Click="Close_Click" Style="{StaticResource CloseBtn}"
                            FontSize="13" Padding="0"/>
                </Grid>
            </Border>

            <!-- Body -->
            <Grid Grid.Row="1" Margin="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: list + actions -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ListBox x:Name="PresetList" Grid.Row="0"
                             Background="#252526" Foreground="#D4D4D4"
                             BorderBrush="#444" BorderThickness="1"
                             SelectionChanged="PresetList_SelectionChanged">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#D4D4D4"/>
                                <Setter Property="Padding" Value="8,5"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#094771"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#2A2D2E"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" FontSize="13"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="+ New" Style="{StaticResource Btn}" Padding="10,5"
                                Margin="0,0,6,0" Click="NewPreset_Click"/>
                        <Button x:Name="DeleteButton" Content="Delete" Style="{StaticResource DangerBtn}"
                                Padding="10,5" IsEnabled="False" Click="DeletePreset_Click"/>
                    </StackPanel>
                </Grid>

                <!-- Right: preset details -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Name" Style="{StaticResource Lbl}"/>
                    <TextBox   Grid.Row="1" x:Name="NameBox" Style="{StaticResource Input}"
                               Margin="0,0,0,12" TextChanged="NameBox_TextChanged"/>

                    <TextBlock Grid.Row="2" Text="Assembly Directory" Style="{StaticResource Lbl}"/>
                    <DockPanel Grid.Row="3" Margin="0,0,0,12">
                        <Button DockPanel.Dock="Right" Content="Browse" Style="{StaticResource Btn}"
                                Padding="10,5" Margin="6,0,0,0" Click="BrowseDir_Click"/>
                        <TextBox x:Name="AssemblyDirBox" Style="{StaticResource Input}"
                                 TextChanged="DetailsChanged"/>
                    </DockPanel>

                    <TextBlock Grid.Row="4" Style="{StaticResource Lbl}" Margin="0,0,0,4">
                        <Run Text="Startup Code"/>
                        <Run Foreground="#555" Text=" — read-only preview, edit in the Startup tab"/>
                    </TextBlock>

                    <Border Grid.Row="5" BorderBrush="#444" BorderThickness="1">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                      Background="#252526">
                            <TextBox x:Name="StartupPreview"
                                     Background="Transparent" Foreground="#D4D4D4"
                                     FontFamily="Consolas" FontSize="12"
                                     BorderThickness="0" IsReadOnly="True"
                                     AcceptsReturn="True" TextWrapping="NoWrap"
                                     Padding="8" VerticalAlignment="Stretch"/>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#252526" BorderBrush="#444"
                    BorderThickness="0,1,0,0" Padding="14,10">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <Button Content="Import..." Style="{StaticResource Btn}" Padding="12,6"
                                Margin="0,0,8,0" Click="Import_Click"/>
                        <Button x:Name="ExportButton" Content="Export..." Style="{StaticResource Btn}"
                                Padding="12,6" IsEnabled="False" Click="Export_Click"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock x:Name="StatusText" Foreground="#888" FontSize="12"
                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Button Content="Save Current Setup" Style="{StaticResource Btn}"
                                Padding="12,6" Margin="0,0,8,0" Click="SaveCurrent_Click"/>
                        <Button x:Name="LoadButton" Content="Load Preset"
                                Style="{StaticResource PrimaryBtn}" Padding="12,6"
                                Margin="0,0,8,0" IsEnabled="False" Click="LoadPreset_Click"/>
                        <Button Content="Close" Style="{StaticResource Btn}"
                                Padding="12,6" Click="Close_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
